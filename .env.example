# ─── Application ───────────────────────────────────────────────────────────
APP_NAME="AI Resume Copilot"
APP_VERSION="1.0.0"
DEBUG=true
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Database ───────────────────────────────────────────────────────────────
POSTGRES_USER=resumeai
POSTGRES_PASSWORD=resumeai_secret
POSTGRES_DB=resume_copilot
DATABASE_URL=postgresql+asyncpg://resumeai:resumeai_secret@localhost:5432/resume_copilot

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@localhost:6379/0

# ─── OpenAI ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# ─── AWS S3 ─────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=resume-copilot-files

# ─── CORS ───────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Rate Limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ─── Sentry ─────────────────────────────────────────────────────────────────
SENTRY_DSN=
